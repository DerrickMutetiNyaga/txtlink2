MONGODB_URI=

# JWT Authentication
JWT_SECRET=

# Encryption Key (for storing HostPinnacle credentials)
ENCRYPTION_KEY=

# Webhook Secret (for verifying delivery report webhooks)
WEBHOOK_SECRET=

# SMS Gateway device token hashing secret
SMS_GATEWAY_TOKEN_SECRET=
# Seconds since last heartbeat/sync to consider gateway online (default 180)
GATEWAY_ONLINE_THRESHOLD_SECONDS=180

# SMS fallback / provider retry (Render cron calls POST /api/internal/sms-fallback/scan)
SMS_FALLBACK_ENABLED=true
SMS_PROVIDER_RETRY_ENABLED=true
SMS_FALLBACK_STALE_MINUTES=7
SMS_PROVIDER_RETRY_WAIT_MINUTES=7
CRON_SECRET=

# Base URL for the app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Owner/Super Admin Configuration
OWNER_EMAIL=
OWNER_USER_ID=

# HostPinnacle SMS API Configuration
HOSTPINNACLE_BASE_URL=https://smsportal.hostpinnacle.co.ke
HOSTPINNACLE_USERID=
HOSTPINNACLE_PASSWORD=
HOSTPINNACLE_API_KEY=
HOSTPINNACLE_STATUS_ENDPOINT=/SMSApi/report/status

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SMS Delivery-Status Worker (Render Background Worker) ───────────────
# Max messages claimed per worker cycle
BATCH_SIZE=500
# Sleep between cycles when there is no due work (ms)
POLL_INTERVAL_MS=5000
# How long a claimed message stays locked to one worker (seconds)
CLAIM_LEASE_SECONDS=120
# HostPinnacle status API request timeout (ms)
HOSTPINNACLE_TIMEOUT_MS=10000
# HTTP retries per status lookup (429/5xx/network errors)
MAX_RETRIES=3
# Backoff schedule for re-checking pending messages (seconds per attempt)
RETRY_INTERVALS_SECONDS=30,120,300,900,1800,3600,10800,21600,43200,86400
# Provider API rate limit (requests per second)
RATE_LIMIT_PER_SECOND=10
# Concurrent status lookups inside one worker
WORKER_CONCURRENCY=10
# Mark still-pending messages provider_timeout after this many hours
PROVIDER_FINAL_TIMEOUT_HOURS=72
# Circuit breaker: consecutive failures before opening
CIRCUIT_BREAKER_FAILURE_THRESHOLD=10
# Circuit breaker: cooldown before probing again (ms)
CIRCUIT_BREAKER_COOLDOWN_MS=60000
# Unique worker instance ID (leave empty to auto-generate)
WORKER_ID=
# Log level: debug | info | warn | error
LOG_LEVEL=info
